# ================================================================
# IoT — Variáveis de Ambiente
# cp .env.example .env  →  preencha os valores antes de subir
# NUNCA commite o .env com valores reais
# ================================================================

# ── NATS ─────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ── Redis (db 2 = IoT state) ─────────────────────────────────
REDIS_URL=redis://redis:6379/2

# ── MQTT Broker ───────────────────────────────────────────────
MQTT_BROKER=mqtt://mqtt-broker:1883
MQTT_USER=orchestrator
MQTT_PASSWORD=changeme

LOG_LEVEL=info
