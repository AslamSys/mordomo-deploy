// OpenClaw — Mordomo Gateway Config (minimal)
// Only gateway access is pre-configured. All LLM providers, models,
// channels (WhatsApp, Telegram, etc.) are configured by the user
// through the OpenClaw onboarding UI after first access.
{
  gateway: {
    port: 18789,
    bind: "lan",
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
    controlUi: {
      allowedOrigins: ["*"],
      allowInsecureAuth: true,
      dangerouslyDisableDeviceAuth: true,
    },
  },
}
