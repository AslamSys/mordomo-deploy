# mordomo-vault environment
# Copy to .env and fill in values BEFORE running for the first time.
# NEVER commit this file with real values.

# NATS broker (default: infra stack)
NATS_URL=nats://mordomo-nats:4222

# AES-256 master key — 64 hex chars (32 bytes)
# Generate with: python -c "import os,binascii; print(binascii.hexlify(os.urandom(32)).decode())"
# WARNING: losing this key makes ALL stored secrets unrecoverable. Back it up securely.
VAULT_MASTER_KEY=

# Path inside container (keep default unless you know what you're doing)
VAULT_DB_PATH=/data/vault.db
