# ================================================================
# Brain — Variáveis de Ambiente
# cp .env.example .env  →  preencha os valores antes de subir
# NUNCA commite o .env com valores reais
# ================================================================

# ── NATS ─────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ── Redis ────────────────────────────────────────────────────
# db 0 = mordomo-people  |  db 1 = mordomo-general
REDIS_URL=redis://redis:6379/1

# ── Postgres ─────────────────────────────────────────────────
DATABASE_URL=postgresql://aslam:changeme@postgres:5432/aslam

# ── Qdrant (RAG) ─────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=mordomo_conversations
QDRANT_VECTOR_SIZE=768
RAG_ENABLED=true

# ── Bifrost Gateway ──────────────────────────────────────────
BIFROST_URL=http://llm-gateway:8080
BIFROST_API_KEY=
EMBEDDING_MODEL=gemini/text-embedding-004

# ── Tier policy (models definidos no Redis db1 pelo deploy) ──
TIER_FALLBACK=simple
TIER_STRICT_MODE=false
TIER_CACHE_TTL=300

# ── Groq fallback direto ──────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Brain — Contexto ─────────────────────────────────────────
CONTEXT_MAX_MESSAGES=12
CONTEXT_TTL_SECONDS=1800
CONTEXT_SUMMARIZE_KEEP=4

# ── Orchestrator — Sessão ────────────────────────────────────
SESSION_TTL_SECONDS=300
VAULT_REQUEST_TIMEOUT=3.0
EVENT_MEMORY_CAPACITY=500
EVENT_MEMORY_RETENTION_HOURS=24

# ── People — Criptografia ────────────────────────────────────
# Gere com: python -c "import os,binascii; print(binascii.hexlify(os.urandom(32)).decode())"
PEOPLE_MASTER_KEY=
RESOLVE_CACHE_TTL=300
PERMISSIONS_CACHE_TTL=60

# ── Vault ─────────────────────────────────────────────────────
# Gere com: python -c "import os,binascii; print(binascii.hexlify(os.urandom(32)).decode())"
# AVISO: perder esta chave torna todos os segredos irrecuperáveis.
VAULT_MASTER_KEY=
VAULT_DB_PATH=/data/vault.db

# ── OpenClaw ──────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=
