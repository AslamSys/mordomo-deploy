# ============================================================
# AslamSys — Infra Environment Variables
# Copie para .env e preencha os valores reais:
#   cp .env.example .env
# NUNCA commite o arquivo .env
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=aslam
POSTGRES_PASSWORD=TROQUE_ISSO
POSTGRES_DB=aslam

# ── LLM Gateway — API Keys dos provedores ───────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Chave mestra do LiteLLM (gerada com: openssl rand -hex 32)
LITELLM_MASTER_KEY=TROQUE_ISSO
