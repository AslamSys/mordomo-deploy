# ============================================================
# AslamSys — Infra Environment Variables
# Copie para .env e preencha os valores reais:
#   cp .env.example .env
# NUNCA commite o arquivo .env
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=aslam
POSTGRES_PASSWORD=TROQUE_ISSO
POSTGRES_DB=aslam

# ── LLM Gateway — API Keys dos provedores ───────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Chave opcional para proteger o endpoint do Bifrost (Authorization: Bearer)
BIFROST_API_KEY=

# Seed de tiers no Redis db1 (executado pelo bootstrap/update)
TIER_SIMPLE_MODEL=gemini/gemini-2.0-flash
TIER_BRAIN_MODEL=gemini/gemini-2.5-pro
TIER_STAKES_MODEL=gemini/gemini-2.5-pro

TIER_SIMPLE_FALLBACK=groq/llama-3.3-70b-versatile
TIER_BRAIN_FALLBACK=groq/llama-3.3-70b-versatile
TIER_STAKES_FALLBACK=groq/llama-3.3-70b-versatile

# ── Docker Hub (para pull de imagens) ────────────────────────
# Crie token em: https://hub.docker.com/settings/security
DOCKERHUB_USERNAME=renaneunao
DOCKERHUB_TOKEN=
