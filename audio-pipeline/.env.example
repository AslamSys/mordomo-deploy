# ================================================================
# Audio Pipeline — Variáveis de Ambiente
# cp .env.example .env  →  preencha os valores antes de subir
# NUNCA commite o .env com valores reais
# ================================================================

# ── NATS ─────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ── Audio Capture / VAD ───────────────────────────────────────
AUDIO_DEVICE_INDEX=0
SAMPLE_RATE=16000
VAD_AGGRESSIVENESS=2
ZMQ_PUB_URL=tcp://*:5555

# ── Wake Word ────────────────────────────────────────────────
WAKE_WORD=mordomo
WAKE_WORD_THRESHOLD=0.7
ZMQ_SUB_URL=tcp://mordomo-audio-capture-vad:5555

# ── Speaker ID / Diarization ─────────────────────────────────
SPEAKER_PROFILES_DIR=/app/profiles
SIMILARITY_THRESHOLD=0.75
MIN_SEGMENT_DURATION=1.0

# ── Source Separation ─────────────────────────────────────────
DEMUCS_MODEL=htdemucs_ft

# ── Speaker Verification ─────────────────────────────────────
PROFILES_PATH=/app/profiles
VERIFICATION_THRESHOLD=0.85

# ── Whisper ASR ───────────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=pt
CHUNK_DURATION_S=2.0
SILENCE_TIMEOUT_S=1.5
BUFFER_MAX_S=30.0

# ── TTS Engine ───────────────────────────────────────────────
TTS_ENGINE=piper
PIPER_MODEL_PATH=/app/models/pt_BR-faber-medium.onnx
PIPER_CONFIG_PATH=/app/models/pt_BR-faber-medium.onnx.json

# ── Audio Bridge ─────────────────────────────────────────────
WS_PORT=3100
ENABLE_LOCAL_PLAYBACK=true

# ── Visual Feedback (LED) ─────────────────────────────────────
LED_COUNT=12
LED_PIN=18
LED_BRIGHTNESS=128

# ── Geral ─────────────────────────────────────────────────────
LOG_LEVEL=info

# ── NATS ─────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ── Audio Capture / VAD ───────────────────────────────────────
AUDIO_DEVICE=default
SAMPLE_RATE=16000
VAD_THRESHOLD=0.5
VAD_SILENCE_MS=500

# ── Wake Word ────────────────────────────────────────────────
WAKE_WORD=mordomo
WAKE_WORD_THRESHOLD=0.7
MODEL_PATH=/app/models

# ── Speaker Verification ─────────────────────────────────────
PROFILES_PATH=/app/profiles
VERIFICATION_THRESHOLD=0.85

# ── Whisper ASR ───────────────────────────────────────────────
MODEL_SIZE=small
MODELS_PATH=/app/models
LANGUAGE=pt
DEVICE=cpu

# ── TTS Engine ───────────────────────────────────────────────
TTS_ENGINE=kokoro
VOICE=default
TTS_LANGUAGE=pt-BR
HTTP_PORT=8080

# ── Audio Bridge ─────────────────────────────────────────────
BUFFER_MS=20

# ── Visual Feedback (LED) ─────────────────────────────────────
LED_COUNT=12
LED_PIN=18
LED_BRIGHTNESS=128

LOG_LEVEL=info
