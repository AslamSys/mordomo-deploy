# ================================================================
# Audio Pipeline — Variáveis de Ambiente
# cp .env.example .env  →  preencha os valores antes de subir
# NUNCA commite o .env com valores reais
# ================================================================

# ── NATS ─────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ── Audio Capture / VAD ───────────────────────────────────────
AUDIO_DEVICE=default
SAMPLE_RATE=16000
VAD_THRESHOLD=0.5
VAD_SILENCE_MS=500

# ── Wake Word ────────────────────────────────────────────────
WAKE_WORD=mordomo
WAKE_WORD_THRESHOLD=0.7
MODEL_PATH=/app/models

# ── Speaker Verification ─────────────────────────────────────
PROFILES_PATH=/app/profiles
VERIFICATION_THRESHOLD=0.85

# ── Whisper ASR ───────────────────────────────────────────────
MODEL_SIZE=small
MODELS_PATH=/app/models
LANGUAGE=pt
DEVICE=cpu

# ── TTS Engine ───────────────────────────────────────────────
TTS_ENGINE=kokoro
VOICE=default
TTS_LANGUAGE=pt-BR
HTTP_PORT=8080

# ── Audio Bridge ─────────────────────────────────────────────
BUFFER_MS=20

# ── Visual Feedback (LED) ─────────────────────────────────────
LED_COUNT=12
LED_PIN=18
LED_BRIGHTNESS=128

LOG_LEVEL=info
